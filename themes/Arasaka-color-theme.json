        "terminal.ansiBlue": "#ff2b2b",
        "terminal.ansiBrightBlue": "#ff2b2b",
        "terminal.ansiGreen": "#00ff00",
        "terminal.ansiBrightGreen": "#00ff00",
        "terminal.ansiYellow": "#ffaa00",
        "terminal.ansiBrightYellow": "#ffaa00",
        "terminal.ansiRed": "#ff2b2b",
        "terminal.ansiBrightRed": "#ff2b2b",
        "terminal.ansiMagenta": "#ff2b2b",
        "terminal.ansiBrightMagenta": "#ff2b2b",
        "terminal.ansiCyan": "#ff2b2b",
        "terminal.ansiBrightCyan": "#ff2b2b",
        "terminal.selectionBackground": "#ff2b2b30"
